<Window x:Class="GrammarFixer.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GrammarFixer Settings"
        Width="480" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <StackPanel Margin="20">
        <TextBlock Text="GrammarFixer Settings" FontSize="18" FontWeight="Bold" Foreground="#E0E0E0" Margin="0,0,0,16"/>

        <!-- Enable -->
        <CheckBox x:Name="EnabledCheck" Content="Enable GrammarFixer" Foreground="#E0E0E0" Margin="0,0,0,10"/>

        <!-- Hotkey -->
        <TextBlock Text="Correction Hotkey" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,4"/>
        <TextBox x:Name="HotkeyBox" Margin="0,0,0,10" Padding="8" Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#3A3A3A" BorderThickness="1"/>

        <!-- Correction Window Hotkey -->
        <TextBlock Text="Correction Window Hotkey" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,10,0,4"/>
        <TextBox x:Name="CorrectionWindowHotkeyBox" Margin="0,0,0,10" Padding="8" Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#3A3A3A" BorderThickness="1"/>

        <!-- Debounce -->
        <TextBlock Text="Debounce (ms)" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,10,0,4"/>
        <TextBox x:Name="DebounceBox" Margin="0,0,0,10" Padding="8" Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#3A3A3A" BorderThickness="1"/>

        <!-- UX Mode -->
        <TextBlock Text="UX Mode" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,10,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="OneClickRadio" Content="One-click rewrite" GroupName="UxMode" Foreground="#E0E0E0" Margin="0,0,12,0"/>
            <RadioButton x:Name="ReviewRadio" Content="Review suggestions overlay" GroupName="UxMode" Foreground="#E0E0E0"/>
        </StackPanel>

        <!-- Allowed Apps -->
        <TextBlock Text="Allowed Apps (one per line, process name)" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,10,0,4"/>
        <TextBox x:Name="AllowedAppsBox" Height="80" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Padding="8"
                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#3A3A3A" BorderThickness="1"/>

        <!-- Denied Apps -->
        <TextBlock Text="Denied Apps (one per line, process name)" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,4"/>
        <TextBox x:Name="DeniedAppsBox" Height="80" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Padding="8"
                 Background="#2D2D2D" Foreground="#E0E0E0" BorderBrush="#3A3A3A" BorderThickness="1"/>

        <!-- Autostart -->
        <CheckBox x:Name="AutostartCheck" Content="Start with Windows" Foreground="#E0E0E0" Margin="0,0,0,16"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="📋 Open Logs" Click="OpenLogs_Click" Width="110" HorizontalAlignment="Left"
                    Padding="8,6" Margin="0,0,8,0" Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0"/>
            <Button Content="Save" Click="Save_Click" Width="80" Margin="0,0,8,0"
                    Background="#007ACC" Foreground="White" BorderThickness="0" Padding="8,6"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80"
                    Background="#3A3A3A" Foreground="#E0E0E0" BorderThickness="0" Padding="8,6"/>
        </StackPanel>
    </StackPanel>
</Window>