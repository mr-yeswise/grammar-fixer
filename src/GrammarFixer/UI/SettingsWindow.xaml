<Window x:Class="GrammarFixer.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GrammarFixer Settings"
        Width="480" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
  <StackPanel Margin="20">
    <TextBlock Text="GrammarFixer Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

    <!-- Enable -->
    <CheckBox x:Name="EnabledCheck" Content="Enable GrammarFixer" Margin="0,0,0,10"/>

    <!-- Mode -->
    <TextBlock Text="Correction Engine" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
      <RadioButton x:Name="StaticModeRadio" Content="Static (Offline)" GroupName="Mode" Margin="0,0,12,0"/>
      <RadioButton x:Name="AiModeRadio" Content="AI (Groq)" GroupName="Mode"/>
    </StackPanel>

    <!-- UX Mode -->
    <TextBlock Text="UX Mode" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
      <RadioButton x:Name="OneClickRadio" Content="One-click rewrite" GroupName="UxMode" Margin="0,0,12,0"/>
      <RadioButton x:Name="ReviewRadio" Content="Review suggestions overlay" GroupName="UxMode"/>
    </StackPanel>

    <!-- Hotkey -->
    <TextBlock Text="Hotkey" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <TextBox x:Name="HotkeyBox" Margin="0,0,0,10" Padding="4"/>

    <!-- Debounce -->
    <TextBlock Text="Debounce (ms)" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <TextBox x:Name="DebounceBox" Margin="0,0,0,10" Padding="4"/>

    <!-- Groq API Key -->
    <TextBlock Text="Groq API Key (stored in Windows Credential Manager)" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
      <PasswordBox x:Name="ApiKeyBox" Width="300" Margin="0,0,8,0" Padding="4"/>
      <Button Content="Save Key" Click="SaveApiKey_Click" Padding="8,4"/>
    </StackPanel>

    <!-- Groq Model -->
    <TextBlock Text="Groq Model" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <ComboBox x:Name="ModelCombo" Margin="0,0,0,10">
      <ComboBoxItem Content="llama-3.1-8b-instant" Tag="llama-3.1-8b-instant"/>
      <ComboBoxItem Content="llama-3.3-70b-versatile" Tag="llama-3.3-70b-versatile"/>
    </ComboBox>

    <!-- Allowed Apps -->
    <TextBlock Text="Allowed Apps (one per line, process name)" FontWeight="SemiBold" Margin="0,0,0,4"/>
    <TextBox x:Name="AllowedAppsBox" Height="80" AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Padding="4"/>

    <!-- Autostart -->
    <CheckBox x:Name="AutostartCheck" Content="Start with Windows" Margin="0,0,0,16"/>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Save" Click="Save_Click" Width="80" Margin="0,0,8,0"
              Background="#3498DB" Foreground="White" BorderThickness="0" Padding="8,6"/>
      <Button Content="Cancel" Click="Cancel_Click" Width="80"
              Padding="8,6"/>
    </StackPanel>
  </StackPanel>
</Window>
