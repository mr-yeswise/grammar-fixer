<Window x:Class="GrammarFixer.UI.FloatingButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GrammarFixer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Focusable="False"
        IsHitTestVisible="True"
        Opacity="0.92">

  <Window.Resources>
    <DropShadowEffect x:Key="BtnShadow"
                      BlurRadius="8"
                      ShadowDepth="2"
                      Opacity="0.28"
                      Color="#222222"/>
  </Window.Resources>

  <!-- Quillbot-style floating pill -->
  <Border x:Name="PillBorder"
          Background="#5B4FE8"
          CornerRadius="20"
          Padding="10,6"
          Cursor="Hand"
          Effect="{StaticResource BtnShadow}"
          MouseEnter="Pill_MouseEnter"
          MouseLeave="Pill_MouseLeave"
          MouseLeftButtonDown="Pill_Click">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <!-- Sparkle icon -->
      <TextBlock Text="&#10024;"
                 FontSize="13"
                 VerticalAlignment="Center"
                 Margin="0,0,5,0"/>
      <!-- Label -->
      <TextBlock x:Name="BtnLabel"
                 Text="Fix"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="White"
                 VerticalAlignment="Center"/>
    </StackPanel>
  </Border>
</Window>
