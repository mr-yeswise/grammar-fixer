<Window x:Class="GrammarFixer.UI.CorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GrammarFixer.UI"
        mc:Ignorable="d"
        Title="GrammarFixer"
        Height="600" Width="750"
        MinHeight="450" MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GrammarFixer;component/UI/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:DiffColorConverter x:Key="DiffColorConverter"/>
            <local:DiffDecorationConverter x:Key="DiffDecorationConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="3" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#252526" CornerRadius="8,8,0,0" Margin="-12,-12,-12,0" Padding="12,8">
                <Grid>
                    <TextBlock Text="GrammarFixer" 
                               Foreground="#E0E0E0" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="\u2715" Width="28" Height="28" Style="{StaticResource FlatButtonStyle}"
                                ToolTip="Close (Esc)" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Input Text Area -->
            <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" 
                    CornerRadius="0,0,6,6" Margin="0,0,0,8" Padding="0">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#333333" BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <Grid>
                            <TextBlock Text="Original Text (paste or type here)" 
                                       Foreground="#A0A0A0" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InputCharCount" 
                                       Foreground="#6A9955" FontSize="11" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <TextBox x:Name="InputBox"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="13"
                             Background="#1E1E1E" Foreground="#D4D4D4"
                             BorderThickness="0"
                             Padding="10"
                             TextWrapping="Wrap"
                             TextChanged="InputBox_TextChanged"
                             KeyDown="InputBox_KeyDown"/>
                </DockPanel>
            </Border>

            <!-- Divider -->
            <Separator Grid.Row="2" Background="#3A3A3A" Margin="0,8" Height="1"/>

            <!-- Corrected Text with Diff View -->
            <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" 
                    CornerRadius="6,6,0,0" Margin="0,0,0,8" Padding="0">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#333333" BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <Grid>
                            <TextBlock Text="Corrected Text (auto-updates as you type)" 
                                       Foreground="#A0A0A0" FontSize="12" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="OutputCharCount" Foreground="#6A9955" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock x:Name="EditsCount" Foreground="#CE9178" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="DiffScrollViewer" 
                                  VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Auto"
                                  Padding="10">
                        <ItemsControl x:Name="DiffItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Consolas" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{Binding Type, Converter={StaticResource DiffColorConverter}}"
                                               TextDecorations="{Binding Type, Converter={StaticResource DiffDecorationConverter}}">
                                        <Run Text="{Binding Text}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Processing Indicator -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" 
                        Margin="0,0,0,8" x:Name="ProcessingPanel" Visibility="Collapsed">
                <ProgressBar Width="100" Height="4" IsIndeterminate="True" 
                             Background="#333333" Foreground="#007ACC" BorderThickness="0"/>
                <TextBlock Text="Analyzing..." Foreground="#A0A0A0" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Copy Corrected" Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8" Margin="8,0,0,0" Click="CopyCorrected_Click"/>
                <Button Content="Copy to Clipboard" Style="{StaticResource SecondaryButtonStyle}"
                        Padding="16,8" Margin="8,0,0,0" Click="ApplyClipboard_Click"/>
                <Button Content="Replace Selection" Style="{StaticResource AccentButtonStyle}"
                        Padding="16,8" Margin="8,0,0,0" Click="SendToField_Click"
                        ToolTip="Pastes corrected text into the last active text field, replacing your selection (Ctrl+Enter)"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>